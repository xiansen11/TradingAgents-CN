# TradingAgents-CN Docker鐜閰嶇疆
# 馃惓 姝ゆ枃浠朵笓闂ㄧ敤浜嶥ocker瀹瑰櫒鍐呯殑鐜鍙橀噺閰嶇疆
# 馃攼 閲嶈锛氳淇敼 API 瀵嗛挜涓烘偍鐨勭湡瀹炲瘑閽?
# ===== Docker鐜鏍囪瘑 =====
DOCKER_CONTAINER=true

# ===== 蹇呴渶鐨凙PI瀵嗛挜 =====

# 馃嚚馃嚦 闃块噷鐧剧偧 API 瀵嗛挜 (鎺ㄨ崘锛屽浗浜уぇ妯″瀷锛屼腑鏂囦紭鍖?
# 鑾峰彇鍦板潃: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_ENABLED=false

# 馃 DeepSeek API 瀵嗛挜 (鎺ㄨ崘锛屾€т环姣旈珮)
# 鑾峰彇鍦板潃: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ENABLED=false

# 馃寪 OpenAI API 瀵嗛挜 (鍙€夛紝闇€瑕佸浗澶栫綉缁?
# 鑾峰彇鍦板潃: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ENABLED=false

# 馃 鏂囧績涓€瑷€锛堢櫨搴﹀崈甯嗭級API 瀵嗛挜
# 鑾峰彇鍦板潃: https://cloud.baidu.com/product/wenxinworkshop
QIANFAN_API_KEY=your_qianfan_api_key_here
QIANFAN_ENABLED=false

# 馃攳 Google AI API 瀵嗛挜 (鍙€夛紝鐢ㄤ簬Gemini妯″瀷)
# 鑾峰彇鍦板潃: https://ai.google.dev/
# 娉ㄦ剰锛氬鏋滀笉浣跨敤 Google Gemini锛岃淇濇寔 GOOGLE_ENABLED=false
# 濡傛灉 API Key 鏃犳晥锛岀郴缁熶細鑷姩闄嶇骇鍒板叾浠栨ā鍨?GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_ENABLED=false

# 馃 Anthropic API 瀵嗛挜 (鍙€夛紝鐢ㄤ簬Claude妯″瀷)
# 鑾峰彇鍦板潃: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_ENABLED=false

# 馃寪 OpenRouter API 瀵嗛挜 (鍙€夛紝鑱氬悎澶氫釜AI妯″瀷)
# 鑾峰彇鍦板潃: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_ENABLED=false

# 馃敆 AiHubMix API 瀵嗛挜 (鍙€夛紝鑱氬悎澶氫釜AI妯″瀷)
# 鑾峰彇鍦板潃: https://aihubmix.com/
AIHUBMIX_API_KEY=your_aihubmix_api_key_here
AIHUBMIX_ENABLED=false

# 馃 AI302 API 瀵嗛挜 (鍙€?
AI302_API_KEY=your_ai302_api_key_here
AI302_ENABLED=false

# 馃嚚馃嚦 纭呭熀娴佸姩 API 瀵嗛挜锛堝彲閫夛級
# 鑾峰彇鍦板潃: https://www.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 馃敡 One API / New API锛堝彲閫夛紝鑷儴缃茶仛鍚堝钩鍙帮級
# 鑾峰彇鍦板潃:
#   - One API: https://github.com/songquanpeng/one-api
#   - New API: https://github.com/Calcium-Ion/new-api
ONEAPI_API_KEY=your_oneapi_api_key_here
ONEAPI_BASE_URL=http://localhost:3000/v1

# 閫氱敤OpenAI鍏煎鎻愪緵鍟?API 瀵嗛挜 (鐢ㄤ簬鑷畾涔夌鐐?
CUSTOM_OPENAI_API_KEY=your-custom-openai-api-key

# 馃搱 Tushare API Token锛堟帹鑽愶紝涓撲笟A鑲℃暟鎹級
# 鑾峰彇鍦板潃: https://tushare.pro/weborder/#/login?reg=tacn
# 鑾峰彇姝ラ锛氭敞鍐岃处鍙?-> 閭楠岃瘉 -> 鑾峰彇Token
# 娉ㄦ剰锛氬厤璐圭敤鎴锋湁璋冪敤棰戠巼闄愬埗锛屽缓璁崌绾хН鍒嗗埌2000绉垎浠ヤ笂锛屽疄鏃惰鎯呴渶瑕佸彟澶栦氦璐?TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_ENABLED=false

# 馃搳 FinnHub API 瀵嗛挜 (鍙€夛紝鐢ㄤ簬鑾峰彇閲戣瀺鏁版嵁)
# 鑾峰彇鍦板潃: https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key_here

# ===== 浠ｇ悊閰嶇疆 =====
# 閰嶇疆闇€瑕佺粫杩囦唬鐞嗙殑鍩熷悕锛堝浗鍐呮暟鎹簮锛?NO_PROXY=localhost,127.0.0.1,eastmoney.com,push2.eastmoney.com,82.push2.eastmoney.com,82.push2delay.eastmoney.com,gtimg.cn,sinaimg.cn,api.tushare.pro,baostock.com

# ===== 鏁版嵁婧愰厤缃?=====

# 馃幆 榛樿涓浗鑲＄エ鏁版嵁婧?# 鍙€夊€? tushare, akshare, baostock
DEFAULT_CHINA_DATA_SOURCE=akshare

# Tushare鏉冮檺绛夌骇閰嶇疆锛堢敤浜庨€熺巼闄愬埗锛?# 鍙€夊€? free(120娆?鍒?, basic(300娆?鍒?, standard(800娆?鍒?, premium(2000娆?鍒?, vip(5000娆?鍒?
TUSHARE_TIER=standard
TUSHARE_RATE_LIMIT_SAFETY_MARGIN=0.8

# ===== 鍦ㄧ嚎宸ュ叿閰嶇疆 =====
ONLINE_TOOLS_ENABLED=false
ONLINE_NEWS_ENABLED=true
REALTIME_DATA_ENABLED=true

# ===== Reddit API 閰嶇疆 (鍙€? =====
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=TradingAgents-CN/1.0

# ===== 鏁版嵁搴撻厤缃?=====

# 馃敡 鏁版嵁搴撳惎鐢ㄥ紑鍏?MONGODB_ENABLED=true
REDIS_ENABLED=true

# MongoDB閰嶇疆锛圖ocker鐜浣跨敤鏈嶅姟鍚嶏紝甯﹁璇侊級
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=tradingagents123
MONGODB_DATABASE=tradingagentscn
MONGODB_AUTH_SOURCE=admin
MONGODB_URL=mongodb://admin:tradingagents123@mongodb:27017/tradingagentscn?authSource=admin
MONGO_URI=mongodb://admin:tradingagents123@mongodb:27017/tradingagentscn?authSource=admin
MONGO_DB=tradingagentscn
MONGODB_CONNECTION_STRING=mongodb://admin:tradingagents123@mongodb:27017/tradingagentscn?authSource=admin
MONGODB_DATABASE_NAME=tradingagentscn
USE_MONGODB_STORAGE=true

# Redis閰嶇疆锛圖ocker鐜浣跨敤鏈嶅姟鍚嶏紝甯﹀瘑鐮侊級
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=tradingagents123
REDIS_DB=0
REDIS_URL=redis://:tradingagents123@redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_RETRY_ON_TIMEOUT=true

# MongoDB杩炴帴姹犻厤缃?MONGO_MAX_CONNECTIONS=100
MONGO_MIN_CONNECTIONS=10
# MongoDB瓒呮椂鍙傛暟锛堟绉掞級- 鐢ㄤ簬澶勭悊澶ч噺鍘嗗彶鏁版嵁
# connectTimeoutMS: 杩炴帴瓒呮椂鏃堕棿锛堥粯璁?0绉掞紝鍘熶负10绉掞級
# socketTimeoutMS: 濂楁帴瀛楄秴鏃舵椂闂达紙榛樿60绉掞紝鍘熶负20绉掞級
# serverSelectionTimeoutMS: 鏈嶅姟鍣ㄩ€夋嫨瓒呮椂鏃堕棿锛堥粯璁?绉掞級
MONGO_CONNECT_TIMEOUT_MS=30000
MONGO_SOCKET_TIMEOUT_MS=60000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# ===== 瀹夊叏閰嶇疆 =====

# 馃攼 JWT閰嶇疆 (鐢ㄤ簬鐢ㄦ埛璁よ瘉)
JWT_SECRET=docker-jwt-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# CSRF淇濇姢
CSRF_SECRET=docker-csrf-secret-key-change-in-production-2024
BCRYPT_ROUNDS=12

# ===== API鏈嶅姟閰嶇疆 =====

# 馃殌 API鏈嶅姟鍩虹閰嶇疆
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 鍘嗗彶鍏煎閰嶇疆锛堝凡搴熷純锛屼絾淇濈暀鍏煎鎬э級
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# 馃敆 CORS閰嶇疆
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:80", "http://localhost:8000"]
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=*

# 馃搳 闃熷垪鍜屽苟鍙戦厤缃?QUEUE_MAX_SIZE=10000
QUEUE_VISIBILITY_TIMEOUT=300
QUEUE_MAX_RETRIES=3

# 骞跺彂鎺у埗
DEFAULT_USER_CONCURRENT_LIMIT=3
GLOBAL_CONCURRENT_LIMIT=50
DEFAULT_DAILY_QUOTA=1000

# Worker閰嶇疆
WORKER_HEARTBEAT_INTERVAL=30

# 閫熺巼闄愬埗
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100

# 馃搧 鏂囦欢涓婁紶閰嶇疆
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# 馃搳 鐩戞帶閰嶇疆
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=60

# ===== 鏃ュ織閰嶇疆 =====
TRADINGAGENTS_LOG_LEVEL=INFO
TRADINGAGENTS_LOG_DIR=/app/logs
TRADINGAGENTS_LOG_FILE=/app/logs/tradingagents.log
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE=logs/tradingagents.log

# ===== 鏁版嵁鐩綍閰嶇疆 =====
TRADINGAGENTS_DATA_DIR=/app/data
TRADINGAGENTS_CACHE_DIR=/app/data/cache
TRADINGAGENTS_SESSIONS_DIR=/app/data/sessions
TRADINGAGENTS_LOGS_DIR=/app/data/logs
TRADINGAGENTS_CONFIG_DIR=/app/data/config
TRADINGAGENTS_TEMP_DIR=/app/data/temp
TRADINGAGENTS_RESULTS_DIR=/app/data/analysis_results

# ===== Python閰嶇疆 =====
# 绂佺敤Python瀛楄妭鐮佺敓鎴?(鍙€夛紝鐢ㄤ簬寮€鍙戠幆澧?
PYTHONDONTWRITEBYTECODE=1

# ===== 鍐呭瓨鍜岀紦瀛橀厤缃?=====
# 馃 鍐呭瓨鍔熻兘鍚敤寮€鍏?(榛樿鍚敤)
# 璁剧疆涓?false 鍙互绂佺敤ChromaDB鍐呭瓨鍔熻兘锛岃В鍐砏indows 10鍏煎鎬ч棶棰?MEMORY_ENABLED=true

# ===== 浣跨敤缁熻鍜屾垚鏈窡韪厤缃?=====
# 馃敡 Token浣跨敤缁熻鍚敤寮€鍏?(榛樿鍚敤)
ENABLE_COST_TRACKING=true

# 馃挵 鎴愭湰璀﹀憡闃堝€?(浜烘皯甯侊紝榛樿100鍏?
COST_ALERT_THRESHOLD=100.0

# 馃搳 鏈€澶т娇鐢ㄨ褰曟暟閲?(榛樿10000鏉?
MAX_USAGE_RECORDS=10000

# ===== 鏃跺尯閰嶇疆 =====
TZ=Asia/Shanghai
TIMEZONE=Asia/Shanghai

# ===== 缂撳瓨閰嶇疆 =====
TA_USE_APP_CACHE=true
CACHE_TTL=3600
SCREENING_CACHE_TTL=1800
SESSION_EXPIRE_HOURS=24

# ===== 鑲＄エ鍩虹淇℃伅鍚屾璋冨害閰嶇疆 =====
SYNC_STOCK_BASICS_ENABLED=true
SYNC_STOCK_BASICS_TIME=06:30

# ===== 瀹炴椂琛屾儏鍏ュ簱浠诲姟閰嶇疆 =====
QUOTES_INGEST_ENABLED=true
QUOTES_INGEST_INTERVAL_SECONDS=360

# 鍚敤鎺ュ彛杞崲鏈哄埗
# - true: 杞祦浣跨敤 Tushare rt_k 鈫?AKShare涓滄柟璐㈠瘜 鈫?AKShare鏂版氮璐㈢粡
# - false: 鎸夐粯璁や紭鍏堢骇浣跨敤锛圱ushare > AKShare锛?QUOTES_ROTATION_ENABLED=true

# Tushare rt_k 鎺ュ彛姣忓皬鏃惰皟鐢ㄦ鏁伴檺鍒?# - 鍏嶈垂鐢ㄦ埛: 2 娆★紙Tushare 瀹樻柟闄愬埗锛屾瘡灏忔椂2娆★級
# - 浠樿垂鐢ㄦ埛: 鍙缃洿楂橈紙濡?1000锛夛紝鏍规嵁鎮ㄧ殑鏉冮檺璋冩暣
QUOTES_TUSHARE_HOURLY_LIMIT=2

# 鑷姩妫€娴?Tushare rt_k 鎺ュ彛鏉冮檺
# - true: 棣栨杩愯鑷姩妫€娴嬫潈闄愶紝浠樿垂鐢ㄦ埛浼氭敹鍒伴珮棰戦噰闆嗗缓璁?# - false: 涓嶆娴嬶紝鎸夐厤缃繍琛?QUOTES_AUTO_DETECT_TUSHARE_PERMISSION=true

# 浼戝競鏈?鍚姩鍏滃簳琛ユ暟锛堝～鍏呬笂涓€绗旀敹鐩樺揩鐓э級
QUOTES_BACKFILL_ON_STARTUP=true
QUOTES_BACKFILL_ON_OFFHOURS=true

# ===== Tushare鏁版嵁鍚屾鏈嶅姟閰嶇疆 =====
# Tushare缁熶竴鏁版嵁鍚屾鎬诲紑鍏?TUSHARE_UNIFIED_ENABLED=false
# 鍩虹淇℃伅鍚屾
TUSHARE_BASIC_INFO_SYNC_ENABLED=false
TUSHARE_BASIC_INFO_SYNC_CRON=0 2 * * *
# 琛屾儏鍚屾锛堜氦鏄撴椂闂存瘡1鍒嗛挓锛?TUSHARE_QUOTES_SYNC_ENABLED=false
TUSHARE_QUOTES_SYNC_CRON=*/1 9-15 * * 1-5
# 鍘嗗彶鏁版嵁鍚屾锛堝伐浣滄棩16鐐癸級
TUSHARE_HISTORICAL_SYNC_ENABLED=false
TUSHARE_HISTORICAL_SYNC_CRON=0 16 * * 1-5
# 璐㈠姟鏁版嵁鍚屾锛堝懆鏃ュ噷鏅?鐐癸級
TUSHARE_FINANCIAL_SYNC_ENABLED=false
TUSHARE_FINANCIAL_SYNC_CRON=0 3 * * 0
# 鐘舵€佹鏌ワ紙姣忓皬鏃讹級
TUSHARE_STATUS_CHECK_ENABLED=false
TUSHARE_STATUS_CHECK_CRON=0 * * * *

# 馃殌 Tushare鏁版嵁鍒濆鍖栭厤缃?# 棣栨閮ㄧ讲鏃剁殑鍘嗗彶鏁版嵁澶╂暟 (榛樿1骞达紝>=3650鍒欏悓姝ュ叏鍘嗗彶)
TUSHARE_INIT_HISTORICAL_DAYS=365
# 鍒濆鍖栨壒澶勭悊澶у皬
TUSHARE_INIT_BATCH_SIZE=100
# 鏄惁鍦ㄥ簲鐢ㄥ惎鍔ㄦ椂鑷姩妫€鏌ュ苟鍒濆鍖栨暟鎹?TUSHARE_INIT_AUTO_START=false

# ===== AKShare鏁版嵁鍚屾鏈嶅姟閰嶇疆 =====
# AKShare缁熶竴鏁版嵁鍚屾鎬诲紑鍏?AKSHARE_UNIFIED_ENABLED=false
# 鍩虹淇℃伅鍚屾
AKSHARE_BASIC_INFO_SYNC_ENABLED=false
AKSHARE_BASIC_INFO_SYNC_CRON=0 3 * * *
# 琛屾儏鍚屾锛堜氦鏄撴椂闂存瘡30鍒嗛挓锛岄伩鍏嶉鐜囬檺鍒讹級
AKSHARE_QUOTES_SYNC_ENABLED=false
AKSHARE_QUOTES_SYNC_CRON=*/30 9-15 * * 1-5
# 鍘嗗彶鏁版嵁鍚屾锛堝伐浣滄棩17鐐癸級
AKSHARE_HISTORICAL_SYNC_ENABLED=false
AKSHARE_HISTORICAL_SYNC_CRON=0 17 * * 1-5
# 璐㈠姟鏁版嵁鍚屾锛堝懆鏃ュ噷鏅?鐐癸級
AKSHARE_FINANCIAL_SYNC_ENABLED=false
AKSHARE_FINANCIAL_SYNC_CRON=0 4 * * 0
# 鐘舵€佹鏌ワ紙姣忓皬鏃?0鍒嗭級
AKSHARE_STATUS_CHECK_ENABLED=false
AKSHARE_STATUS_CHECK_CRON=30 * * * *

# 馃殌 AKShare鏁版嵁鍒濆鍖栭厤缃?# 棣栨閮ㄧ讲鏃剁殑鍘嗗彶鏁版嵁澶╂暟 (榛樿1骞?
AKSHARE_INIT_HISTORICAL_DAYS=365
# 鍒濆鍖栨壒澶勭悊澶у皬
AKSHARE_INIT_BATCH_SIZE=100
# 鏄惁鍦ㄥ簲鐢ㄥ惎鍔ㄦ椂鑷姩妫€鏌ュ苟鍒濆鍖栨暟鎹?AKSHARE_INIT_AUTO_START=false

# ===== 鍒嗘瀽甯堟暟鎹幏鍙栭厤缃?=====
# 甯傚満鍒嗘瀽鍥炴函澶╂暟锛堢敤浜庢妧鏈垎鏋愶級
# 鎺ㄨ崘鍊硷細60澶╋紙鍙鐩朚A60绛夋墍鏈夊父鐢ㄦ妧鏈寚鏍囷級
MARKET_ANALYST_LOOKBACK_DAYS=365
# 鍩烘湰闈㈠垎鏋愶細鍥哄畾鑾峰彇10澶╂暟鎹紝鍒嗘瀽鏈€杩?澶╋紙鏃犻渶閰嶇疆锛?
# ===== BaoStock鏁版嵁鍚屾鏈嶅姟閰嶇疆 =====
# BaoStock缁熶竴鏁版嵁鍚屾鎬诲紑鍏?BAOSTOCK_UNIFIED_ENABLED=false
# 鍩虹淇℃伅鍚屾
BAOSTOCK_BASIC_INFO_SYNC_ENABLED=false
BAOSTOCK_BASIC_INFO_SYNC_CRON=0 4 * * *
# 鏃绾垮悓姝?(宸ヤ綔鏃ユ敹鐩樺悗16:00)
BAOSTOCK_DAILY_QUOTES_SYNC_ENABLED=false
BAOSTOCK_DAILY_QUOTES_SYNC_CRON=0 16 * * 1-5
# 琛屾儏鍚屾锛堜氦鏄撴椂闂存瘡15鍒嗛挓锛?BAOSTOCK_QUOTES_SYNC_ENABLED=false
BAOSTOCK_QUOTES_SYNC_CRON=*/15 9-15 * * 1-5
# 鍘嗗彶鏁版嵁鍚屾锛堝伐浣滄棩18鐐癸級
BAOSTOCK_HISTORICAL_SYNC_ENABLED=false
BAOSTOCK_HISTORICAL_SYNC_CRON=0 18 * * 1-5
# 鐘舵€佹鏌ワ紙姣忓皬鏃?5鍒嗭級
BAOSTOCK_STATUS_CHECK_ENABLED=false
BAOSTOCK_STATUS_CHECK_CRON=45 * * * *

# 馃殌 BaoStock鏁版嵁鍒濆鍖栭厤缃?# 棣栨閮ㄧ讲鏃剁殑鍘嗗彶鏁版嵁澶╂暟 (榛樿1骞?
BAOSTOCK_INIT_HISTORICAL_DAYS=365
# 鍒濆鍖栨壒澶勭悊澶у皬 (BaoStock寤鸿杈冨皬鎵规)
BAOSTOCK_INIT_BATCH_SIZE=50
# 鏄惁鍦ㄥ簲鐢ㄥ惎鍔ㄦ椂鑷姩妫€鏌ュ苟鍒濆鍖栨暟鎹?BAOSTOCK_INIT_AUTO_START=false

# ===== 鏂伴椈鏁版嵁鍚屾鏈嶅姟閰嶇疆 =====
NEWS_SYNC_ENABLED=false
NEWS_SYNC_CRON=0 */2 * * *
NEWS_SYNC_HOURS_BACK=24
NEWS_SYNC_MAX_PER_SOURCE=50

MCP_ENABLED=true
MCP_FINANCE_TRANSPORT=streamable_http
MCP_FINANCE_URL=http://host.docker.internal:3030/mcp
MCP_CHINA_STOCK_TRANSPORT=streamable_http
MCP_CHINA_STOCK_URL=http://host.docker.internal:9898/mcp
MCP_TIMEOUT_SECONDS=45
